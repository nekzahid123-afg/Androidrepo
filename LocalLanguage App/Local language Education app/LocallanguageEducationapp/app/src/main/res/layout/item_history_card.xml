<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="15dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: Solid Blue Grid Area for the Main Question -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary_blue"
            android:gravity="center"
            android:paddingVertical="35dp"
            android:paddingHorizontal="20dp">

            <TextView
                android:id="@+id/historyQuestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What is Computer?"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textDirection="ltr"
                android:gravity="center" />
        </LinearLayout>

        <!-- Body: Pashto Answer and Action Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layoutDirection="rtl">

            <TextView
                android:id="@+id/historyAnswerPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="کمپیوټر یو بریښنایی وسیله ده چې معلومات پروسس کوي..."
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp" />

            <!-- Action Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <!-- Saved Indicator -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/offlineIndicator"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="#4CAF50"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="خوندي شوی"
                        android:textColor="#4CAF50"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Actions -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/starIcon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginEnd="16dp"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#FFD700" />

                    <ImageView
                        android:id="@+id/deleteIcon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@android:drawable/ic_menu_delete"
                        app:tint="#E53935" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>